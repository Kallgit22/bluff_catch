rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // matches/{matchId}
    // -------------------------------------------------------------------------
    // All game state is server-authoritative: only Cloud Functions
    // (admin SDK) write to match documents. Clients only read.
    // -------------------------------------------------------------------------
    match /matches/{matchId} {
      allow read:  if request.auth != null;
      allow write: if false; // Only Cloud Functions can write
    }

    // -------------------------------------------------------------------------
    // rooms/{roomId}
    // -------------------------------------------------------------------------
    // Room states are server-authoritative.
    // -------------------------------------------------------------------------
    match /rooms/{roomId} {
      allow read:  if request.auth != null;
      allow write: if false; // Only Cloud Functions can write
    }

    // -------------------------------------------------------------------------
    // users/{userId}
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // Allow read if the profile is NOT private, OR if the requester is the owner
      allow read: if (resource == null) || (resource.data.isPrivate != true) || (request.auth != null && request.auth.uid == userId);
      
      // Allow create/update ONLY if the requester is the owner of the document
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny access to all other collections.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
